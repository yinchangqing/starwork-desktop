{
  "name": "starwork-desktop",
  "productName": "StarWork",
  "version": "0.1.2",
  "description": "StarWork desktop wrapper for 日程.HTML",
  "author": "StarWork",
  "repository": {
    "type": "git",
    "url": "https://github.com/yinchangqing/starwork-desktop.git"
  },
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "pack": "electron-packager . \"StarWork\" --platform=win32 --arch=x64 --out=dist --overwrite --ignore=\"^/dist\"",
    "build": "npm run pack",
    "dist": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "yauzl": "^3.1.3"
  },
  "build": {
    "appId": "com.starwork.desktop",
    "productName": "StarWork",
    "files": [
      "main.js",
      "preload.js",
      "日程.HTML"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "publisherName": "StarWork",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
